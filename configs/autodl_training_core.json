{
  "repo_root": "/root/autodl-tmp/project-1/conan-rhythm",
  "raw_root": "/root/autodl-tmp/data/LibriTTS",
  "core_docs": [
    "README.md",
    "docs/autodl_training_handoff.md",
    "docs/training_plan.md"
  ],
  "core_configs": {
    "teacher_stage1_train100": "egs/conan_emformer_rhythm_v2_teacher_offline_train100.yaml",
    "teacher_stage1_train100_360": "egs/conan_emformer_rhythm_v2_teacher_offline_train100_360.yaml",
    "teacher_stage1_train100_360_pause_recall": "egs/conan_emformer_rhythm_v2_teacher_offline_train100_360_pause_recall.yaml",
    "teacher_stage2_polish_base": "egs/conan_emformer_rhythm_v2_teacher_offline_train100_360.yaml",
    "teacher_future_external_ref_reference": "egs/conan_emformer_rhythm_v2_student_ref_bootstrap.yaml",
    "optional_student_kd": "egs/conan_emformer_rhythm_v2_student_kd.yaml",
    "optional_student_retimed": "egs/conan_emformer_rhythm_v2_student_retimed.yaml"
  },
  "core_scripts": {
    "verify": "scripts/verify_core_training_assets.py",
    "prepare_train100": "scripts/autodl_prepare_train100_formal.sh",
    "prepare_train100_360": "scripts/autodl_prepare_train100_360_formal.sh",
    "train_stage1": "scripts/autodl_train_stage1.sh",
    "recovery_v3_trainonly": "scripts/autodl_recovery_mixed100360_v3_trainonly.sh",
    "resume_stage1_pause_recall": "scripts/autodl_resume_stage1_pause_recall.sh",
    "monitor_stage1_metrics": "scripts/monitor_stage1_metrics.py"
  },
  "core_outputs": {
    "train100_processed": "data/processed/libritts_train100_formal",
    "train100_binary": "data/binary/libritts_train100_formal_rhythm_v6",
    "warmup_ckpt_20k": "checkpoints/teacher_offline_train100_warmup/model_ckpt_steps_20000.ckpt",
    "train360_trainonly_processed": "data/processed/libritts_train360_formal_trainset",
    "train360_trainonly_binary": "data/binary/libritts_train360_formal_trainset_rhythm_v6"
  },
  "command_templates": {
    "verify": "python scripts/verify_core_training_assets.py",
    "prepare_train100": "bash scripts/autodl_prepare_train100_formal.sh",
    "prepare_train100_with_f0": "WITH_F0=1 bash scripts/autodl_prepare_train100_formal.sh",
    "train100_real_smoke": "MAX_UPDATES=1000 VAL_CHECK_INTERVAL=200 bash scripts/autodl_train_stage1.sh egs/conan_emformer_rhythm_v2_teacher_offline_train100.yaml teacher_offline_train100_real_smoke",
    "train100_warmup_5k": "MAX_UPDATES=5000 VAL_CHECK_INTERVAL=1000 bash scripts/autodl_train_stage1.sh egs/conan_emformer_rhythm_v2_teacher_offline_train100.yaml teacher_offline_train100_warmup",
    "train100_continue_20k": "RESET=0 MAX_UPDATES=20000 VAL_CHECK_INTERVAL=1000 bash scripts/autodl_train_stage1.sh egs/conan_emformer_rhythm_v2_teacher_offline_train100.yaml teacher_offline_train100_warmup",
    "prepare_train100_360": "bash scripts/autodl_prepare_train100_360_formal.sh",
    "train100_360_stage1": "MAX_UPDATES=180000 VAL_CHECK_INTERVAL=5000 bash scripts/autodl_train_stage1.sh egs/conan_emformer_rhythm_v2_teacher_offline_train100_360.yaml teacher_offline_train100_360_stage1",
    "monitor_stage1": "tail -f logs/stage1_recovery_mixed100360_v3_trainonly.log",
    "recovery_v3_trainonly": "bash scripts/autodl_recovery_mixed100360_v3_trainonly.sh",
    "resume_stage1_pause_recall": "STOP_EXISTING=1 bash scripts/autodl_resume_stage1_pause_recall.sh",
    "monitor_stage1_metrics": "python scripts/monitor_stage1_metrics.py --log logs/stage1_recovery_mixed100360_v3_trainonly.log --tail 5"
  }
}
